# Persisted secrets for the agentic harness.
# COPY this to agentic/.env, fill in, and `chmod 600 agentic/.env`.
# agentic/.env is gitignored + dockerignored — NEVER committed or baked into the image.
# run_smoke.sh auto-loads it (plain KEY=value; no `export` needed).

# --- Agent auth — ONE of (subscription preferred; far cheaper than API credits) ---
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-REPLACE_ME      # from `claude setup-token` (needs Pro/Max)
# ANTHROPIC_API_KEY=sk-ant-...                        # fallback (API credits)

# --- Globus Compute identity (endpoint auth) ---
# Your login db for a throwaway smoke; a dedicated test identity is the Plan B ideal.
HPCB_TEST_GLOBUS_DB=/Users/gusellerm/.globus_compute/storage.db

# --- Scoped SSH test user (defaults shown; usually leave unset) ---
# HPCB_TEST_SSH_KEY=/Users/gusellerm/.ssh/hpcbridge-test
# HPCB_TEST_SSH_USER=hpcbridge-test
